# thread-keeper configuration — copy to ~/.threadkeeper/.env and uncomment what
# you want to change. Everything has a sensible default, so an empty file is
# fine. Precedence: real environment vars > ~/.threadkeeper/.env > these defaults.
#
# Override the file location with THREADKEEPER_ENV_FILE=/path/to/.env
# (read by threadkeeper.config — pydantic-settings).

# ── core paths ──
# THREADKEEPER_DB=~/.threadkeeper/db.sqlite
# THREADKEEPER_TASK_LOG_DIR=/tmp/thread-keeper-tasks
# CLAUDE_SKILLS_DIR=~/.claude/skills          # note: unprefixed (Claude's own var)
# CLAUDE_PROJECTS_DIR=~/.claude/projects       # note: unprefixed

# ── embeddings / semantic search ──
# THREADKEEPER_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# THREADKEEPER_EMBED_BACKEND=onnx              # onnx | sentence-transformers
# THREADKEEPER_NO_EMBEDDINGS=false             # true on slim children (FTS-only)

# ── identity / process origin ──
# THREADKEEPER_CLIENT=claude
# THREADKEEPER_WRITE_ORIGIN=foreground         # foreground | background_review
# THREADKEEPER_SPAWNED_CHILD=false             # set by spawn() on children
# THREADKEEPER_DISABLE_BG_DAEMONS=false        # true = never start any bg daemon thread (tests / one-shot CLI)

# ── ingest ──
# THREADKEEPER_INGEST_CAP=50
# THREADKEEPER_INGEST_INTERVAL_S=3
# THREADKEEPER_INGEST_WINDOW_S=600
# THREADKEEPER_SELF_CID_TTL_S=5

# ── nudges / brief ──
# THREADKEEPER_MEMORY_NUDGE_INTERVAL=10
# THREADKEEPER_SKILL_NUDGE_INTERVAL=10
# THREADKEEPER_BRIEF_LEAN=false                # set by the SessionStart hook only
# THREADKEEPER_BRIEF_NO_THREAD_NUDGE=false     # set by hook-capable CLIs only
# THREADKEEPER_AUTO_REVIEW=false

# ── spawn budget ──
# THREADKEEPER_SPAWN_BUDGET_MB=3072            # 0 disables budget enforcement
# THREADKEEPER_SPAWN_ESTIMATE_SLIM_MB=500
# THREADKEEPER_SPAWN_ESTIMATE_FULL_MB=1500
# THREADKEEPER_SPAWN_BUDGET_POLL_S=10

# ── memory guard ──
# THREADKEEPER_MEMORY_GUARD_POLL_S=30          # 0 disables the daemon
# THREADKEEPER_MEMORY_GUARD_WARN_MB=1536
# THREADKEEPER_MEMORY_GUARD_KILL_MB=3072
# THREADKEEPER_MEMORY_GUARD_AGG_WARN_MB=2048
# THREADKEEPER_MEMORY_GUARD_AGG_KILL_MB=3072
# THREADKEEPER_MEMORY_GUARD_RECLAIM_MB=1024
# THREADKEEPER_MEMORY_GUARD_TARGET_SERVERS=1
# THREADKEEPER_MEMORY_GUARD_RETIRE_IDLE_S=900
# THREADKEEPER_MEMORY_GUARD_RETIRE_LIVE=false
# THREADKEEPER_MEMORY_GUARD_NOTIFY=true
# THREADKEEPER_MEMORY_GUARD_COOLDOWN_S=300

# ── background daemons (all 0 = off by default; opt in) ──
# THREADKEEPER_SHADOW_REVIEW_INTERVAL_S=0
# THREADKEEPER_SHADOW_REVIEW_WINDOW_S=900
# THREADKEEPER_SHADOW_REVIEW_MIN_CHARS=500
# THREADKEEPER_CURATOR_INTERVAL_S=0
# THREADKEEPER_CURATOR_MIN_LESSONS=3
# THREADKEEPER_CURATOR_REPORTS_DIR=             # default: <db dir>/curator
# THREADKEEPER_CURATOR_DESTRUCTIVE=             # any non-empty value = on
# THREADKEEPER_EXTRACT_INTERVAL_S=0
# THREADKEEPER_EXTRACT_WINDOW_MIN=30
# THREADKEEPER_CANDIDATE_REVIEW_INTERVAL_S=0
# THREADKEEPER_CANDIDATE_REVIEW_MIN=3
# THREADKEEPER_PROBE_INTERVAL_S=0
# THREADKEEPER_PROBE_COOLDOWN_S=604800
# THREADKEEPER_EVOLVE_REVIEW_INTERVAL_S=0
# THREADKEEPER_EVOLVE_REVIEW_MIN=2
# THREADKEEPER_EVOLVE_APPLY_INTERVAL_S=0       # applier daemon tick (s); picks the top promoted+unapplied suggestion and opens a PR implementing it. 0=off (manual evolve_apply still works)
# THREADKEEPER_THREAD_JANITOR_INTERVAL_S=0
# THREADKEEPER_THREAD_IDLE_CLOSE_DAYS=1
# THREADKEEPER_DIALECTIC_MINE_INTERVAL_S=0
# THREADKEEPER_DIALECTIC_VALIDATE_INTERVAL_S=0
# THREADKEEPER_DIALECTIC_VALIDATE_MIN=5
# THREADKEEPER_DIALECTIC_MAX_NEW_CLAIMS=3

# ── judge panel ──
# THREADKEEPER_PANEL_SIZE=3
# THREADKEEPER_PANEL_ROLES=skeptic,critic,generator
# THREADKEEPER_PANEL_REQUIRE_SKEPTIC=true
# THREADKEEPER_PANEL_VOTE_WEIGHT=1.0
# THREADKEEPER_PANEL_MODEL=
# THREADKEEPER_PANEL_EFFORT=

# ── spawn routing (replaces the old spawn.toml; nested __ keys, lowercased) ──
#   default agent when a role has no explicit pin ("" = use the active CLI):
# THREADKEEPER_SPAWN__DEFAULT=claude
#   per-role CLI: THREADKEEPER_SPAWN__LOOP__<ROLE>=<cli>  — the 7 spawn roles:
# THREADKEEPER_SPAWN__LOOP__SHADOW_OBSERVER=claude
# THREADKEEPER_SPAWN__LOOP__ARCHIVIST=claude
# THREADKEEPER_SPAWN__LOOP__CURATOR=claude
# THREADKEEPER_SPAWN__LOOP__CANDIDATE_REVIEWER=claude
# THREADKEEPER_SPAWN__LOOP__EVOLVE_REVIEWER=claude
# THREADKEEPER_SPAWN__LOOP__EVOLVE_APPLIER=claude   # writes code + opens a PR — keep on a strong coding CLI
# THREADKEEPER_SPAWN__LOOP__PROBE_RUNNER=claude
# THREADKEEPER_SPAWN__LOOP__DIALECTIC_VALIDATOR=claude
#   model pin per CLI or per role: THREADKEEPER_SPAWN__MODEL__<KEY>=<model>
# THREADKEEPER_SPAWN__MODEL__CLAUDE=sonnet
# THREADKEEPER_SPAWN__MODEL__DIALECTIC_VALIDATOR=opus
# THREADKEEPER_SPAWN__MODEL__EVOLVE_APPLIER=opus    # it writes code → pin the strongest model
