# thread-keeper configuration — copy to ~/.threadkeeper/.env and uncomment what
# you want to change. Everything has a sensible default, so an empty file is
# fine. Precedence: real environment vars > ~/.threadkeeper/.env > these defaults.
#
# Override the file location with THREADKEEPER_ENV_FILE=/path/to/.env
# (read by threadkeeper.config — pydantic-settings).
#
# Canonical THREADKEEPER_* spellings are listed below. At startup/hot-reload,
# unknown THREADKEEPER_* keys in the process environment are logged as warnings
# so mistyped host env-block overrides are visible.

# ── core paths ──
# THREADKEEPER_DB=~/.threadkeeper/db.sqlite
# THREADKEEPER_TASK_LOG_DIR=/tmp/thread-keeper-tasks
# CLAUDE_SKILLS_DIR=~/.claude/skills          # note: unprefixed (Claude's own var)
# CLAUDE_PROJECTS_DIR=~/.claude/projects       # note: unprefixed

# ── embeddings / semantic search ──
# THREADKEEPER_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# THREADKEEPER_EMBED_BACKEND=onnx              # onnx | sentence-transformers
# THREADKEEPER_NO_EMBEDDINGS=false             # true on slim children (FTS-only)

# ── identity / process origin ──
# THREADKEEPER_CLIENT=claude
# THREADKEEPER_WRITE_ORIGIN=foreground         # foreground | background_review
# THREADKEEPER_SPAWNED_CHILD=false             # set by spawn() on children
# THREADKEEPER_DISABLE_BG_DAEMONS=false        # true = never start any bg daemon thread (tests / one-shot CLI)

# ── auto-update ──
# THREADKEEPER_AUTO_UPDATE_INTERVAL_S=86400    # daily MCP self-update check; 0 disables
# THREADKEEPER_AUTO_UPDATE_RESTART=true        # exit after applying an update so the host restarts on new code
# THREADKEEPER_AUTO_UPDATE_TIMEOUT_S=600       # max seconds for git/pip update commands
# THREADKEEPER_AUTO_UPDATE_VERIFY_PROVENANCE=true
# THREADKEEPER_AUTO_UPDATE_PYPI_BASE_URL=https://pypi.org
# THREADKEEPER_AUTO_UPDATE_EXPECTED_PUBLISHER_REPOSITORY=po4erk91/thread-keeper
# THREADKEEPER_AUTO_UPDATE_EXPECTED_PUBLISHER_WORKFLOW=publish.yml
# THREADKEEPER_AUTO_UPDATE_EXPECTED_PUBLISHER_ENVIRONMENT=pypi

# ── skill updater ──
# THREADKEEPER_SKILL_UPDATE_INTERVAL_S=302400  # twice weekly installed-skill update/mirror check; 0 disables
# THREADKEEPER_SKILL_UPDATE_TIMEOUT_S=300      # max seconds for upstream skill source downloads
# THREADKEEPER_SKILL_UPDATE_SOURCES=openai/skills@main:skills/.curated  # comma-separated owner/repo@ref:path specs
# THREADKEEPER_SKILL_UPDATE_INFER_SOURCES=true # infer source by skill name from configured source roots
# THREADKEEPER_SKILL_UPDATE_ALLOW_UNTRACKED_OVERWRITE=false  # do not overwrite inferred untracked local edits by default

# ── hot-config reload (#2) ──
# THREADKEEPER_CONFIG_WATCH_INTERVAL_S=2        # poll ~/.claude/settings.json and hot-apply changed env knobs in-process; 0 disables
# THREADKEEPER_CONFIG_WATCH_PATH=               # override the watched settings.json path (default ~/.claude/settings.json)

# ── ingest ──
# THREADKEEPER_INGEST_CAP=50
# THREADKEEPER_INGEST_INTERVAL_S=3
# THREADKEEPER_INGEST_WINDOW_S=600
# THREADKEEPER_SELF_CID_TTL_S=5

# ── nudges / brief ──
# THREADKEEPER_MEMORY_NUDGE_INTERVAL=10
# THREADKEEPER_SKILL_NUDGE_INTERVAL=10
# THREADKEEPER_BRIEF_LEAN=false                # set by the SessionStart hook only
# THREADKEEPER_BRIEF_NO_THREAD_NUDGE=false     # set by hook-capable CLIs only
# THREADKEEPER_AUTO_REVIEW=false

# ── spawn budget ──
# THREADKEEPER_SPAWN_BUDGET_MB=3072            # 0 disables budget enforcement
# THREADKEEPER_SPAWN_ESTIMATE_SLIM_MB=500
# THREADKEEPER_SPAWN_ESTIMATE_FULL_MB=1500
# THREADKEEPER_SPAWN_BUDGET_POLL_S=10
# THREADKEEPER_SPAWN_TOKEN_BUDGET=0             # 0 disables daily token ceiling; compares recorded 24h task tokens
# THREADKEEPER_SPAWN_COST_BUDGET_USD=0          # 0 disables daily dollar ceiling; compares recorded 24h task cost_usd
# THREADKEEPER_SPAWN_MAX_RUNTIME_S=3600         # 0 disables wall-clock watchdog
# THREADKEEPER_SPAWN_KILL_GRACE_S=10
# THREADKEEPER_SPAWN_TIMEOUT_RETRY_LIMIT=3      # immediate continuation retries after watchdog kill; 0 disables
# THREADKEEPER_SPAWN_TIMEOUT_RETRY_DELAY_S=0
# THREADKEEPER_TASK_RETENTION_DAYS=30           # consolidate() keeps ended tasks within this age; 0 disables the age bound
# THREADKEEPER_TASK_RETENTION_COUNT=1000        # consolidate() also keeps this many newest ended tasks; 0 disables the count bound
# THREADKEEPER_MENUBAR_AUTO_LAUNCH=true       # macOS: auto install/launch status menu-bar app on MCP startup

# ── memory guard ──
# THREADKEEPER_MEMORY_GUARD_POLL_S=30          # 0 disables the daemon
# THREADKEEPER_MEMORY_GUARD_WARN_MB=1536
# THREADKEEPER_MEMORY_GUARD_KILL_MB=3072
# THREADKEEPER_MEMORY_GUARD_AGG_WARN_MB=2048
# THREADKEEPER_MEMORY_GUARD_AGG_KILL_MB=3072
# THREADKEEPER_MEMORY_GUARD_RECLAIM_MB=1024
# THREADKEEPER_MEMORY_GUARD_TARGET_SERVERS=1
# THREADKEEPER_MEMORY_GUARD_RETIRE_IDLE_S=900
# THREADKEEPER_MEMORY_GUARD_RETIRE_LIVE=false
# THREADKEEPER_MEMORY_GUARD_NOTIFY=true
# THREADKEEPER_MEMORY_GUARD_COOLDOWN_S=300

# ── background daemons (all 0 = off by default; opt in) ──
# THREADKEEPER_SHADOW_REVIEW_INTERVAL_S=0
# THREADKEEPER_SHADOW_REVIEW_WINDOW_S=900
# THREADKEEPER_SHADOW_REVIEW_MIN_CHARS=500
# THREADKEEPER_CURATOR_INTERVAL_S=0
# THREADKEEPER_CURATOR_MIN_LESSONS=3
# THREADKEEPER_CURATOR_REPORTS_DIR=             # default: <db dir>/curator
# THREADKEEPER_CURATOR_DESTRUCTIVE=1            # default 1: curator applies its own changes; set 0 for advisory REPORT-only
# THREADKEEPER_CURATOR_SNAPSHOT_RETENTION=10    # destructive pre-mutation snapshots retained under <reports_dir>/snapshots
# THREADKEEPER_EXTRACT_INTERVAL_S=0
# THREADKEEPER_EXTRACT_WINDOW_MIN=30
# THREADKEEPER_CANDIDATE_REVIEW_INTERVAL_S=0
# THREADKEEPER_CANDIDATE_REVIEW_MIN=3
# THREADKEEPER_PROBE_INTERVAL_S=0             # 1800 = 30 min active reliability tracking
# THREADKEEPER_PROBE_COOLDOWN_S=604800       # 86400 = 1d active per-category cooldown
# THREADKEEPER_EVOLVE_REVIEW_INTERVAL_S=0
# THREADKEEPER_EVOLVE_REVIEW_MIN=2
# THREADKEEPER_EVOLVE_APPLY_INTERVAL_S=0       # applier tick (s); applies latest complete Curator report first, then promoted evolve PR work. 0=off (manual tools still work)
# THREADKEEPER_EVOLVE_REPO_ROOT=               # pin the thread-keeper checkout the reviewer/applier branch+test+PR against. Empty=auto: package parent (editable install.sh) else an auto-cloned managed checkout under the DB dir
# THREADKEEPER_EVOLVE_AUTO_CLONE=1             # auto-provision (clone + .venv with [semantic,dev]) a managed checkout on PyPI/site-packages installs so the evolve loops work by default. 0=disable (then needs an editable install or EVOLVE_REPO_ROOT)
# THREADKEEPER_EVOLVE_REPO_URL=https://github.com/po4erk91/thread-keeper   # git URL the managed checkout is cloned from
# THREADKEEPER_EVOLVE_REPO_BRANCH=main         # branch the managed checkout tracks
# THREADKEEPER_ROADMAP_CLAIM_RACE_WINDOW_S=3   # multi-host TOCTOU window: after posting a claim, wait this long before re-fetching to detect a competing claim. 0=skip race detection (single-host setups)
# THREADKEEPER_ROADMAP_ISSUE_MAX_ATTEMPTS=3    # poison-issue dead-letter cap: after this many implementer spawns with no PR, the roadmap issue gets a `blocked` label + one summary comment and drops out of the auto-drain until a human intervenes
# THREADKEEPER_ROADMAP_ISSUE_BACKOFF_BASE_S=172800  # base failure-backoff window (s); doubles per attempt (base*2^(n-1), capped 30d). Defers re-selecting a repeatedly-aborting issue beyond the 24h claim TTL
# THREADKEEPER_THREAD_JANITOR_INTERVAL_S=0
# THREADKEEPER_THREAD_IDLE_CLOSE_DAYS=1
# THREADKEEPER_DIALECTIC_MINE_INTERVAL_S=0
# THREADKEEPER_DIALECTIC_VALIDATE_INTERVAL_S=0
# THREADKEEPER_DIALECTIC_VALIDATE_MIN=5
# THREADKEEPER_DIALECTIC_VALIDATE_BATCH_SIZE=50
# THREADKEEPER_DIALECTIC_MAX_NEW_CLAIMS=3

# ── judge panel ──
# THREADKEEPER_PANEL_SIZE=3
# THREADKEEPER_PANEL_ROLES=skeptic,critic,generator
# THREADKEEPER_PANEL_REQUIRE_SKEPTIC=true
# THREADKEEPER_PANEL_VOTE_WEIGHT=1.0
# THREADKEEPER_PANEL_MODEL=
# THREADKEEPER_PANEL_EFFORT=

# ── spawn routing (replaces the old spawn.toml; nested __ keys, lowercased) ──
#   default agent when a role has no explicit pin ("" = use the active CLI):
# THREADKEEPER_SPAWN__DEFAULT=claude
#   supported CLI keys: claude, codex, antigravity (agy executable alias), gemini (legacy), copilot
#   per-role CLI: THREADKEEPER_SPAWN__LOOP__<ROLE>=<cli>  — the 8 spawn roles:
# THREADKEEPER_SPAWN__LOOP__SHADOW_OBSERVER=claude
# THREADKEEPER_SPAWN__LOOP__ARCHIVIST=claude
# THREADKEEPER_SPAWN__LOOP__CURATOR=claude
# THREADKEEPER_SPAWN__LOOP__CANDIDATE_REVIEWER=claude
# THREADKEEPER_SPAWN__LOOP__EVOLVE_REVIEWER=claude
# THREADKEEPER_SPAWN__LOOP__EVOLVE_APPLIER=claude   # writes code + opens a PR — keep on a strong coding CLI
# THREADKEEPER_SPAWN__LOOP__PROBE_RUNNER=claude
# THREADKEEPER_SPAWN__LOOP__DIALECTIC_VALIDATOR=claude
#   model pin per CLI or per role: THREADKEEPER_SPAWN__MODEL__<KEY>=<model>
# THREADKEEPER_SPAWN__MODEL__CLAUDE=opus
# THREADKEEPER_SPAWN__MODEL__CODEX=gpt-5.5
# THREADKEEPER_SPAWN__MODEL__AGY="Gemini 3.1 Pro (High)"
# THREADKEEPER_SPAWN__MODEL__GEMINI=gemini-3.1-pro-preview
# THREADKEEPER_SPAWN__MODEL__DIALECTIC_VALIDATOR=opus
# THREADKEEPER_SPAWN__MODEL__EVOLVE_APPLIER=opus    # it writes code → pin the strongest model
