# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.eggs/

# Virtual envs
.venv/
venv/
env/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local config / runtime state (must never land in git)
.env
*.bak
*.bak.*
.bak.*

# Per-CLI runtime / per-user state — see skill
# 'never-commit-cli-runtime-dirs'. These directories hold session
# locks, scheduled task state, hook caches, settings.local.json,
# personal conversation history. Per-user, per-machine — never
# commit.
.claude/
.codex/
.gemini/
.copilot/
.threadkeeper/
.cursor/
.windsurf/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Tooling caches
.ruff_cache/
.mypy_cache/
.cache/

# Local-only test artifacts
tests/__pycache__/
/test-results/
/coverage/
/outputs
